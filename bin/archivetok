#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.join(__dir__, "..", "lib"))
require "bundler/setup"
require "optparse"
require "colorize"
require "archivetok"

USAGE = <<~USAGE
  Usage: archivetok URL [URL...] [options]

  Options:
      --output-dir DIR    Directory to save files (default: current directory)
      --json              Save sidecar as JSON instead of plain text
      --pages N           Number of pages to fetch for profile listing (default: 1)
      -h, --help          Show this help message

  Config file:
      ./.archivetok.yml or ~/.archivetok.yml
      Supported keys: output_dir, json_sidecar, pages

  Examples:
      archivetok https://www.tiktok.com/@user/video/123456
      archivetok --output-dir ~/Downloads/tiktok https://vm.tiktok.com/abc123/
      archivetok https://www.tiktok.com/@user          # list videos
      archivetok --pages 3 https://www.tiktok.com/@user
USAGE

options = {}
parser = OptionParser.new do |opts|
  opts.banner = USAGE
  opts.on("--output-dir DIR", "Directory to save files") { |d| options[:output_dir] = d }
  opts.on("--json", "Save sidecar as JSON instead of plain text") { options[:json_sidecar] = true }
  opts.on("--pages N", Integer, "Pages to fetch for profile listing") { |n| options[:pages] = n }
  opts.on("-h", "--help") { puts USAGE; exit }
end

begin
  parser.parse!
rescue OptionParser::InvalidOption => e
  abort "#{e.message}\n\n#{USAGE}"
end

abort USAGE if ARGV.empty?

config = Archivetok::Config.load(options)
puts "Output directory: #{config.output_dir}".white

errors = []

ARGV.each_with_index do |url, i|
  sleep 2 if i > 0

  unless Archivetok::UrlValidator.valid?(url)
    $stderr.puts "Skipping invalid URL: #{url}".red
    errors << url
    next
  end

  if Archivetok::UrlValidator.profile?(url)
    $stderr.puts "\n=> Listing videos for: #{url}".cyan
    video_urls = Archivetok::ProfileExtractor.extract(url, pages: config.pages)
    if video_urls.empty?
      $stderr.puts "  No videos found.".yellow
      errors << url
    else
      $stderr.puts "  Total: #{video_urls.size} video(s)".green
      video_urls.each { |u| $stdout.puts u }
    end
  else
    Archivetok::Processor.new(config).process(url)
  end
rescue Interrupt
  $stderr.puts "\nInterrupted.".yellow
  exit 1
rescue => e
  $stderr.puts "  Error: #{e.message}".red
  errors << url
end

$stderr.puts ""
if errors.any?
  $stderr.puts "Completed with #{errors.size} error(s):".yellow
  errors.each { |u| $stderr.puts "  - #{u}".red }
  exit 1
else
  $stderr.puts "Done.".green
end
